<?xml version="1.0" encoding="UTF-8"?>
<!--
    Arquillian Configuration — GlassFish 6 Remote Container
    =========================================================
    Tells Arquillian where to find the running GlassFish instance.

    Prerequisites:
      1. GlassFish 6 started: ./bin/asadmin start-domain domain1
      2. Admin user configured (see DEPLOYMENT.md)
      3. TechMartDS datasource + JMS destinations configured
-->
<arquillian xmlns="http://jboss.org/schema/arquillian"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://jboss.org/schema/arquillian
            http://jboss.org/schema/arquillian/arquillian_1_0.xsd">

    <defaultProtocol type="Servlet 3.0"/>

    <container qualifier="glassfish-remote" default="true">
        <configuration>
            <!-- GlassFish Admin Console host -->
            <property name="adminHost">localhost</property>
            <!-- Default GlassFish admin port -->
            <property name="adminPort">4848</property>
            <!-- Admin credentials (set during GlassFish setup) -->
            <property name="adminUser">admin</property>
            <property name="adminPassword">admin123</property>
            <!-- Application HTTP port -->
            <property name="httpPort">8080</property>
            <!-- Target domain -->
            <property name="target">server</property>
        </configuration>
    </container>

</arquillian>
